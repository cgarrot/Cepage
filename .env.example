# Core runtime
NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:31945/cepage?schema=public
API_PORT=31947
WEB_PORT=31961

# Local web and API wiring
# Start the local database with: docker compose up -d
# Use a comma-separated list or * for development CORS behavior.
CORS_ORIGIN=http://localhost:31961
NEXT_PUBLIC_API_URL=http://localhost:31947
NEXT_PUBLIC_WS_URL=http://localhost:31947

# Native daemon (apps/daemon) — local HTTP health server for status/CLI
CEPAGE_DAEMON_HEALTH_PORT=31982

# Agent runtime
# AGENT_WORKING_DIRECTORY must point to a real local directory.
AGENT_WORKING_DIRECTORY=.
# Optional: comma-separated absolute paths to additional workflow skill catalogs.
# Each entry can point to a catalog.json file or to a directory containing one.
# These catalogs merge with the built-in library after private and public skills.
# WORKFLOW_SKILLS_EXTRA_PATHS=/home/user/my-skills,/opt/company/skills/catalog.json
WORKFLOW_SKILLS_EXTRA_PATHS=
# Deprecated. Agent execution (agent_run + runtime_*) is now handled by the
# native daemon (apps/daemon), which spawns OpenCode locally — no remote
# OpenCode server is needed. These vars only affect in-API synchronous code
# paths (workflow copilot, file summarizer, agents catalog) when running
# outside Docker. Leave unset for the default native daemon flow.
# OPENCODE_PORT=3939
# OPENCODE_HOST=127.0.0.1

# Runtime tuning
SNAPSHOT_EVENT_INTERVAL=200
# 'api' = the API runs an in-process queue consumer for non-daemon job kinds
# (workflow, connectors, triggers, approvals). 'off' disables it entirely.
# agent_run / runtime_* jobs are always handled by the native daemon (apps/daemon).
EXECUTION_WORKER_MODE=api
EXECUTION_WORKER_POLL_MS=400
EXECUTION_HEARTBEAT_MS=5000
EXECUTION_JOB_LEASE_MS=15000
EXECUTION_SCHEDULER_MS=1000
AUTONOMY_DEFAULT_BUDGET=16

# CIDRs the daemon protocol guard trusts in addition to loopback. Required when
# the API is dockerized and the native daemon hits it from the host: the
# connection arrives via the bridge gateway IP (typically 172.x.y.1), not
# 127.0.0.1. Leave empty for pure localhost setups (API + daemon both on host).
# Format: comma-separated list of IPv4 CIDRs (or bare IPv4 = /32).
# DAEMON_TRUSTED_PEER_CIDRS=172.16.0.0/12,10.0.0.0/8,192.168.0.0/16

# Default host-side parent directory stamped on every new session created via
# POST /api/v1/sessions (and used as an ultimate fallback for
# /sessions/from-skill). MUST be a host path when the API runs in Docker,
# because the native daemon dispatching agent_run jobs resolves it on the
# host filesystem. Leave empty to fall back to `$HOME/cepage_workspaces`.
# Recommended: align with the daemon's CEPAGE_WORKSPACE_ROOT.
CEPAGE_DEFAULT_WORKSPACE_ROOT=

# Generic skill scaffolding (POST /api/v1/sessions/from-skill/:id)
# - Default parent dir for new session workspaces (when the request omits one).
# - Comma/colon-separated whitelist of absolute roots from which the seeder
#   can copy files & directories. Leave empty to disallow directory seeding.
SESSION_FROM_SKILL_DEFAULT_WORKSPACE_ROOT=
SESSION_FROM_SKILL_SEED_ALLOWED_ROOTS=

# ─── Free-form vars consumed by your skills / external services ───
# cepage itself does not require any extra env var beyond the ones above.
# Anything you add below will be passed straight through to the api/worker
# containers in the prod compose (see docker-compose.prod.yml -> env_file),
# so a workflow skill can read whatever URL / API key / flag it expects.
#
# Example: a demo pipeline under examples/ (gitignored locally) may talk to
# four external services. Point each var at a reachable base URL (no trailing slash).
#   MUSIC_AI_STUDIO_URL=http://localhost:3010
#   CLIP_VIDEO_CD_URL=http://localhost:3020
#   YT_PUBLISHER_URL=http://localhost:3030
#   MJ_BROWSER_URL=http://localhost:8765
