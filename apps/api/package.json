{
  "name": "@cepage/api-app",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "prebuild": "pnpm --filter @cepage/db run generate && pnpm --filter @cepage/api run build",
    "build": "nest build",
    "predev": "pnpm --filter @cepage/db run generate && pnpm --filter @cepage/api run build",
    "dev": "node ../../scripts/run-api-dev.mjs",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint src --max-warnings=0",
    "clean": "rm -rf dist"
  },
  "prisma": {
    "schema": "../../packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/websockets": "^11.1.18",
    "@prisma/client": "5.22.0",
    "@cepage/api": "workspace:*",
    "@cepage/config": "workspace:*",
    "@cepage/shared-core": "workspace:*",
    "express": "^4.21.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "prisma": "5.22.0",
    "typescript": "^5.7.3"
  }
}
