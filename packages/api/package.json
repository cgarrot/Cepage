{
  "name": "@cepage/api",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src --max-warnings=0",
    "clean": "rm -rf dist",
    "test": "pnpm build && node ../../scripts/run-node-tests.mjs dist",
    "db:generate": "pnpm --filter @cepage/db run generate"
  },
  "dependencies": {
    "@cepage/agent-core": "workspace:*",
    "@cepage/config": "workspace:*",
    "@cepage/graph-core": "workspace:*",
    "@cepage/shared-core": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/websockets": "^11.1.18",
    "@prisma/client": "5.22.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cron-parser": "^5.5.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "tar": "^7.5.13",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "prisma": "5.22.0",
    "typescript": "^5.7.3"
  }
}
