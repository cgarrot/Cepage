    "@cepage/shared-core": "workspace:*",
    "@cepage/state": "workspace:*",
    "@cepage/ui-kit": "workspace:*",
    "react-markdown": "^9",
    "react-resizable-panels": "^2.1.7",
    "rehype-highlight": "^7",
    "remark-gfm": "^4"
  },
